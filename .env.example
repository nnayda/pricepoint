# =============================================================================
# Home Value Forecast — Environment Variables
# =============================================================================
# Copy this file to .env and adjust values as needed.
#
# BUNDLED INFRA: The defaults below work with `docker compose --profile infra up`
# EXTERNAL INFRA: Override these to point at your existing services, then run
#                 `docker compose up` (without --profile infra)
# =============================================================================

# --- Database (PostGIS) ------------------------------------------------------
# Bundled infra default (local PostGIS container):
DATABASE_URL=postgresql://pricepoint:pricepoint@postgres:5432/pricepoint

# External infra override (uncomment and set your connection string):
# DATABASE_URL=postgresql://user:password@your-postgres-host:5432/pricepoint

# --- S3-compatible Object Storage --------------------------------------------
# Bundled infra default (local MinIO container):
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=pricepoint-data

# External infra override (uncomment for Ceph, AWS S3, etc.):
# S3_ENDPOINT_URL=https://your-s3-endpoint.example.com
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key
# S3_BUCKET=your-bucket-name

# --- MLflow -------------------------------------------------------------------
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_BACKEND_STORE_URI=sqlite:///mlflow.db
MLFLOW_ARTIFACT_ROOT=s3://mlflow-artifacts

# --- Airflow ------------------------------------------------------------------
# Bundled infra default:
AIRFLOW__CORE__SQL_ALCHEMY_CONN=sqlite:////opt/airflow/airflow.db

# External infra override (uncomment for external Airflow):
# AIRFLOW__CORE__SQL_ALCHEMY_CONN=postgresql://airflow:airflow@your-airflow-db:5432/airflow

# --- Valkey (Cache / Message Broker) ------------------------------------------
VALKEY_URL=redis://valkey:6379/0

# --- API ----------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=["http://localhost:3000"]
