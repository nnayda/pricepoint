# =============================================================================
# Home Value Forecast — Environment Variables
# =============================================================================
# Copy this file to .env and adjust values as needed.
#
# DEPLOYMENT OPTIONS:
# 1. App only:           make up              (requires external infra)
# 2. App + core infra:   make up-infra        (postgres, minio, valkey - use external Airflow)
# 3. Everything bundled: make up-all          (includes bundled Airflow + database)
#
# For external infrastructure, override the connection strings below.
# =============================================================================

# --- Database (PostGIS) ------------------------------------------------------
# Bundled infra default (local PostGIS container with separate databases):
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/pricepoint

# --- S3-compatible Object Storage --------------------------------------------
# Bundled infra default (local MinIO container):
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=pricepoint-data

# --- MLflow -------------------------------------------------------------------
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_BACKEND_STORE_URI=sqlite:////mlflow/mlflow.db
MLFLOW_ARTIFACT_ROOT=s3://mlflow-artifacts

# --- Airflow ------------------------------------------------------------------
# Bundled Airflow (use with: make up-all):
# Uses separate 'airflow' database in same PostgreSQL instance
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql://postgres:postgres@postgres:5432/airflow

# --- Valkey (Cache / Message Broker) ------------------------------------------
VALKEY_URL=redis://valkey:6379/0

# --- Redfin Data Directory ----------------------------------------------------
# Host directory mounted into containers at /data/raw/redfin
# Drop Redfin HTML listing files here for processing
REDFIN_DATA_DIR=./data/redfin

# --- API ----------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=["http://localhost:3000"]

# --- Geocoding ----------------------------------------------------------------
# Provider: "nominatim" (default) or "photon"
# GEOCODE_PROVIDER=nominatim
# GEOCODE_URL=https://nominatim.openstreetmap.org/search
# GEOCODE_TIMEOUT=5.0
GEOCODE_RATE_LIMIT_SECONDS=1.0  # set to 0 if using a self-hosted instance

# --- OSRM ---------------------------------------------------------------------
# Configure a self-hosted OSRM instance
# OSRM_BASE_URL="https://osrm.example.com"
OSRM_RATE_LIMIT_SECONDS=1.0 # set to 0 if using a self-hosted instance

# --- FRED API (Economic Indicators) -------------------------------------------
# Get a free API key at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=change-me

# --- Census Bureau ACS (Demographics) ----------------------------------------
# Get a free API key at https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=change-me

# --- Martin Tileserver ---------------------------------------------------------
# Martin connects to the same PostGIS database to serve vector tiles.
# Reuses DATABASE_URL by default; override if needed.
# MARTIN_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/pricepoint

# --- Dev Mode -----------------------------------------------------------------
# Set to true to disable Valkey caching (avoids stale data during development)
DEV_MODE=false

# --- App Configs --------------------------------------------------------------
# see src/pricepoint/config/settings.py for options
TIGER_YEAR=2025
TIGER_STATE_FIPS="37"  # North Carolina
TIGER_COUNTY_FIPS="183"  # Wake County

# --- Notifications (ntfy) ----------------------------------------------------
# Push notifications via ntfy.sh (or self-hosted ntfy server)
# NTFY_ENABLED=true
# NTFY_SERVER_URL=https://ntfy.sh
# NTFY_TOPIC=pricepoint-alerts